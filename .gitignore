// .gitignore
# Rust build output
/target/
**/*.rs.bk

# Cargo
Cargo.lock

# Logs
*.log

# Test / coverage
/coverage/

# OS files
.DS_Store
Thumbs.db

# IDE / editor
.vscode/
.idea/
*.swp
*.swo

# Environment variables
.env
.env.local
.env.*

# WASM / build artifacts (if used)
/dist/
/pkg/

# Soroban / Stellar CLI (optional)
.soroban/
stellar-ledger/